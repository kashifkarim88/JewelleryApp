generator client {
  provider        = "prisma-client-js"
}


datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DATABASE_URL") 
}

model Worker {
id           Int      @id @default(autoincrement())
name         String
phone_number String   @unique
worker_code  String   @unique
createdAt    DateTime @default(now())
updatedAt    DateTime @updatedAt
}

model Category{
  id           Int      @id @default(autoincrement())
  product_name String   @unique
  Abbreviation String   @unique
  product_code String   @unique
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model StockItem {
  id              String   @id @default(cuid())
  createdAt       DateTime @default(now())
  // Core Fields
  itemCode        String @unique
  metal           String   // Gold, Silver, Palladium, etc.
  carat           String?  // 21K, 18K (Mainly for Gold)
  purity          Float?   // Added for Palladium purity % (e.g., 95.0)
  categoryName    String
  productCode     String
  description     String?
  workerName      String
  
  // Measurements
  netWeight       Float
  wastageGram     Float
  wastagePercent  Float
  making          Float
  imageUrl        String?

  // Optional Detail Sections
  stoneDetails    StoneDetail?
  beadDetails     BeadDetail?
  diamondDetails  DiamondDetail?
}

model StoneDetail {
  id          String    @id @default(cuid())
  name        String?
  weight      Float?
  price       Float?
  
  // Relation back to StockItem
  stockItemId String    @unique
  stockItem   StockItem @relation(fields: [stockItemId], references: [id], onDelete: Cascade)
}

model BeadDetail {
  id          String    @id @default(cuid())
  weight      Float?
  price       Float?
  
  // Relation back to StockItem
  stockItemId String    @unique
  stockItem   StockItem @relation(fields: [stockItemId], references: [id], onDelete: Cascade)
}

model DiamondDetail {
  id          String    @id @default(cuid())
  name        String?
  weight      Float?
  color       String?
  cut         String?
  clarity     String?
  rate        Float?
  price       Float?
  
  // Relation back to StockItem
  stockItemId String    @unique
  stockItem   StockItem @relation(fields: [stockItemId], references: [id], onDelete: Cascade)
}