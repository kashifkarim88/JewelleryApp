generator client {
  provider        = "prisma-client-js"
}


datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DATABASE_URL") 
}

model Worker {
id           Int      @id @default(autoincrement())
name         String
phone_number String   @unique
worker_code  String   @unique
createdAt    DateTime @default(now())
updatedAt    DateTime @updatedAt
}

model Category{
  id           Int      @id @default(autoincrement())
  product_name String   @unique
  Abbreviation String   @unique
  product_code String   @unique
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model StockItem {
  id              String   @id @default(cuid())
  createdAt       DateTime @default(now())
  itemCode        String   @unique
  metal           String   
  carat           String?  
  purity          Float?   
  categoryName    String
  productCode     String
  description     String?
  workerName      String
  
  netWeight       Float
  wastageGram     Float
  wastagePercent  Float
  making          Float
  imageUrl        String?

  // UPDATED: Changed from Optional (?) to Array ([])
  stoneDetails    StoneDetail[]
  diamondDetails  DiamondDetail[]
  
  // Kept as Optional (?) assuming only one type of bead entry is needed
  beadDetails     BeadDetail?
}

model StoneDetail {
  id          String    @id @default(cuid())
  name        String?
  weight      Float?
  price       Float?
  squantity   Int?
  
  // Relation back to StockItem
  stockItemId String    // REMOVED @unique here
  stockItem   StockItem @relation(fields: [stockItemId], references: [id], onDelete: Cascade)
}

model DiamondDetail {
  id          String    @id @default(cuid())
  name        String?
  weight      Float?
  color       String?
  cut         String?
  clarity     String?
  rate        Float?
  price       Float?
  dquantity   Int?
  
  // Relation back to StockItem
  stockItemId String    // REMOVED @unique here
  stockItem   StockItem @relation(fields: [stockItemId], references: [id], onDelete: Cascade)
}

// BeadDetail remains the same if it's always a single entry
model BeadDetail {
  id          String    @id @default(cuid())
  weight      Float?
  price       Float?
  
  stockItemId String    @unique
  stockItem   StockItem @relation(fields: [stockItemId], references: [id], onDelete: Cascade)
}